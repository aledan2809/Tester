{
  "name": "@aledan007/tester-service",
  "version": "0.1.0",
  "description": "HTTP server wrapper around @aledan007/tester — T-D2 monorepo split",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "tester-service": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "keywords": [
    "tester",
    "testing",
    "http-server",
    "express"
  ],
  "author": "@aledan007",
  "license": "MIT",
  "dependencies": {
    "@aledan007/tester": "workspace:*",
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "uuid": "^10.0.0",
    "better-sqlite3": "^11.5.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^10.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=18"
  }
}
