# Anthropic API key — required for AI scenario generation and Vision element finding
ANTHROPIC_API_KEY=sk-ant-...

# HTTP server port (default: 3012)
TESTER_PORT=3012

# Bearer token for HTTP server authentication — required when running as a service
# Format: tester_<random-string> (min 32 chars) or legacy format
TESTER_API_SECRET=tester_your-secret-token-here-min-32-chars
